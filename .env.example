# Newsletter provider (MailerLite). Leave unset during local development
# and the signup form will log submissions to the console instead of
# sending them anywhere.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Admin editor (Decap CMS at /admin). Required for the "Log in with GitHub"
# button on /admin to work. See README.md for how to create these.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
